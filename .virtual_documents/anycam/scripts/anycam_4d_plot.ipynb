        # 1. 计算当前位姿
        current_pose = trajectories[i]
        rel_pose = first_pose_inv @ current_pose
        R = rel_pose[:3, :3].cpu().numpy()
        t_vec = rel_pose[:3, 3] * STRETCH_Z
        t_vec_np = t_vec.cpu().numpy() # 转换为 numpy 方便计算
        
        trajectory_history.append(t_vec_np)

        # 2. 生成点云 (相对于当前相机位姿平移)
        depth = depths[i, 0]
