        v_idx, u_idx = torch.where(mask)
        z = depth[v_idx, u_idx]

        x = (u_idx.float() * scale_u - w_img * 0.5) * z / focal_length
        y = (v_idx.float() * scale_v - h_img * 0.5) * z / focal_length
        
